ACMF_ENV=development
ACMF_DEBUG=true
ACMF_HOST=0.0.0.0
ACMF_PORT=8000

ACMF_DATABASE_URL=postgresql+psycopg://acmf:acmf@postgres:5432/acmf
ACMF_REDIS_URL=redis://redis:6379/0
ACMF_NEO4J_URI=bolt://neo4j:7687
ACMF_NEO4J_USERNAME=neo4j
ACMF_NEO4J_PASSWORD=acmfpassword
ACMF_AUTO_MIGRATE_ON_STARTUP=true
ACMF_DB_STARTUP_TIMEOUT_SECONDS=60

ACMF_OPENAI_DEFAULT_BASE_URL=https://api.openai.com/v1
ACMF_OPENAI_DEFAULT_API_KEY=
ACMF_OPENAI_DEFAULT_TIMEOUT_SECONDS=30

ACMF_ADJUDICATOR_PROVIDER=stub
ACMF_ADJUDICATOR_BASE_URL=
ACMF_ADJUDICATOR_API_KEY=
ACMF_ADJUDICATOR_MODEL=gpt-5.4
ACMF_ADJUDICATOR_TIMEOUT_SECONDS=30

ACMF_CONTEXT_ENHANCER_PROVIDER=stub
ACMF_CONTEXT_ENHANCER_BASE_URL=
ACMF_CONTEXT_ENHANCER_API_KEY=
ACMF_CONTEXT_ENHANCER_MODEL=gpt-5.4
ACMF_CONTEXT_ENHANCER_TIMEOUT_SECONDS=30

ACMF_CORTEX_PROVIDER=stub
ACMF_CORTEX_BASE_URL=
ACMF_CORTEX_API_KEY=
ACMF_CORTEX_MODEL=gpt-5.4
ACMF_CORTEX_TIMEOUT_SECONDS=30

ACMF_EMBEDDING_PROVIDER=stub
ACMF_EMBEDDING_BASE_URL=
ACMF_EMBEDDING_API_KEY=
ACMF_EMBEDDING_MODEL=text-embedding-3-small
ACMF_EMBEDDING_DIMENSIONS=1536
ACMF_EMBEDDING_TIMEOUT_SECONDS=30

ACMF_CONTEXT_MAX_OUTPUT_TOKENS=400
ACMF_DEEP_MEMORY_MAX_OUTPUT_TOKENS=500
ACMF_CONTEXT_DEFAULT_CANDIDATE_LIMIT=30
ACMF_DEEP_MEMORY_DEFAULT_CANDIDATE_LIMIT=40
ACMF_SIMPLE_CANDIDATE_LIMIT=10
ACMF_BALANCED_CANDIDATE_LIMIT=30
ACMF_DEEP_CANDIDATE_LIMIT=50
ACMF_SIMPLE_GRAPH_LIMIT=5
ACMF_BALANCED_GRAPH_LIMIT=10
ACMF_DEEP_GRAPH_LIMIT=20
ACMF_QUERY_TEXT_RELEVANCE_THRESHOLD=0.25
ACMF_QUERY_VECTOR_SIMILARITY_THRESHOLD=0.78
ACMF_GRAPH_QUERY_RELEVANCE_THRESHOLD=0.2
ACMF_EVIDENCE_ABSTAIN_THRESHOLD=0.45
ACMF_GRAPH_PROJECTION_BATCH_SIZE=100
ACMF_GRAPH_PROJECTION_MAX_ATTEMPTS=5
ACMF_GRAPH_PROJECTION_RETRY_BACKOFF_SECONDS=300
